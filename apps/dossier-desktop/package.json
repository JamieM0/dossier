{
  "name": "@dossier/dossier-desktop",
  "productName": "Dossier",
  "version": "0.1.13",
  "private": true,
  "type": "module",
  "main": "dist/backend.js",
  "scripts": {
    "tauri": "tauri",
    "preflight:rust": "node ./scripts/check-rust.mjs",
    "preflight:version": "node ./scripts/check-version-sync.mjs",
    "preflight:port": "node ./scripts/check-port.mjs",
    "dev": "node ./scripts/dev-desktop.mjs",
    "dev:desktop": "node ./scripts/dev-desktop.mjs",
    "build:deps": "pnpm -C ../.. -r --filter @dossier/store build",
    "build": "tsc -p tsconfig.json",
    "dist": "pnpm run preflight:rust && pnpm run preflight:version && pnpm run build:deps && pnpm run build && tauri build --config ./src-tauri/tauri.conf.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@dossier/store": "workspace:*"
  },
  "devDependencies": {
    "@tauri-apps/cli": "latest",
    "@types/node": "^22.10.2",
    "cross-env": "^7.0.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
